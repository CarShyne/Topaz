{
  "name": "topaz",
  "version": "0.1.0",
  "description": "Next Level Notes — notes, links, and sync across all your devices.",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "npm run icons && electron-vite build && electron-builder --mac",
    "dist:win": "npm run icons && electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "server": "tsx server/index.ts",
    "build:web": "vite build --config vite.web.config.ts && cp dist-web/index.web.html dist-web/index.html",
    "hub": "tsx server/hub-server.ts",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "deploy": "bash scripts/deploy-topaz.sh",
    "publish": "bash scripts/publish-jt7777.sh",
    "publish:amd64": "bash scripts/publish-jt7777-amd64.sh",
    "publish:arm64": "bash scripts/publish-jt7777-arm64.sh",
    "build:mobile": "vite build --config vite.mobile.config.ts && cp dist-mobile/index.mobile.html dist-mobile/index.html",
    "cap:sync": "npm run build:mobile && npx cap sync ios",
    "cap:open": "npx cap open ios",
    "ipa": "bash scripts/build-ipa.sh",
    "ipa:signed": "bash scripts/build-ipa-signed.sh",
    "icons": "bash scripts/generate-icons.sh",
    "git:local": "bash scripts/setup-local-git.sh",
    "package:win": "bash scripts/package-windows.sh",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@capacitor/browser": "^7.0.5",
    "@capacitor/core": "^7.6.6",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/ios": "^7.6.6",
    "@capacitor/keyboard": "^7.0.6",
    "@capacitor/preferences": "^7.0.4",
    "@capacitor/status-bar": "^7.0.6",
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-markdown": "^6.3.3",
    "@codemirror/language": "^6.11.0",
    "@codemirror/search": "^6.5.10",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.8",
    "@lezer/highlight": "^1.2.1",
    "bcryptjs": "^3.0.2",
    "bonjour-service": "^1.4.1",
    "chokidar": "^4.0.3",
    "cors": "^2.8.5",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "express": "^5.1.0",
    "gray-matter": "^4.0.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "uuid": "^11.1.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.18",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.5.0",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "app.topaz.notes",
    "productName": "Topaz",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "mac": {
      "icon": "resources/icon-1024.png",
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "resources/icon-1024.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "resources/icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
